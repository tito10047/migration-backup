{
  "name": "tito10047/migration-backup",
  "type": "symfony-bundle",
  "license": "MIT",
  "description": "Symfony bundle that automatically backs up your database (MySQL, PostgreSQL, SQLite) before running migrations. Supports Gzip compression and automatic cleanup.",
  "authors": [
    {
      "name": "Jozef Môstka",
      "email": "jozef@mostka.sk",
      "homepage": "https://vsetkosada.sk/en"
    }
  ],
  "minimum-stability": "stable",
  "require": {
    "php": ">=8.2",
    "doctrine/doctrine-bundle": "^2.12|^3.0",
    "doctrine/orm": "^2.19|^3.1.0",
    "doctrine/persistence": "^3.4|^4.0",
    "symfony/console": "^6.4|^7.4|^8.0",
    "symfony/doctrine-bridge": "^6.4|^7.4|^8.0",
    "symfony/event-dispatcher": "^6.4|^7.4|^8.0",
    "symfony/filesystem": "^6.4|^7.4|^8.0",
    "symfony/process": "^6.4|^7.4|^8.0"
  },
  "require-dev": {
    "doctrine/doctrine-migrations-bundle": "^3.7",
    "phpunit/phpunit": "^9.5",
    "symfony/dotenv": "^6.4|^7.4|^8.0",
    "symfony/framework-bundle": "^6.4|^7.4|^8.0",
    "symfony/phpunit-bridge": "^6.4|^7.4|^8.0",
    "symfony/yaml": "^6.4|^7.4|^8.0",
    "ext-zlib": "*"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  },
  "autoload": {
    "psr-4": {
      "Tito10047\\MigrationBackup\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tito10047\\MigrationBackup\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "phpunit": "vendor/bin/phpunit --display-warnings --display-skipped --display-deprecations --display-errors --display-notices"
  }
}
